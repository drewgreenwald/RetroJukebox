<?xml version="1.0" encoding="UTF-8"?>
<!--
  RetroJukebox Installer — WiX v4
  ════════════════════════════════════════════════════════════════════════════
  HOW TO BUILD:
    1. Install .NET 8 SDK and WiX v4 tools:
         dotnet tool install --global wix --version 4.0.5
         wix extension add WixToolset.UI.wixext/4.0.5
         wix extension add WixToolset.Util.wixext/4.0.5

    2. Publish the main app as a self-contained Windows x64 build:
         cd RetroJukebox\RetroJukebox
         dotnet publish -c Release -r win-x64 --self-contained true ^
           -p:PublishSingleFile=false ^
           -o bin\Publish

    3. Build the installer:
         cd RetroJukebox.Installer
         dotnet build -c Release
       Output: bin\Release\RetroJukebox.msi
  ════════════════════════════════════════════════════════════════════════════
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="RetroJukebox"
           Manufacturer="RetroJukebox"
           Version="1.0.0"
           UpgradeCode="B3E7F2A1-9C4D-4E8B-A6F0-2D1C8E5B9A3F"
           Scope="perMachine"
           Compressed="true"
           InstallerVersion="500">

    <!-- Allow clean upgrades (remove old version before installing new) -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of RetroJukebox is already installed." />

    <!-- Standard WiX install UI with licence page, directory page, progress -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Suppress licence agreement page (no EULA for personal project) -->
    <UIRef Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

    <!-- Installer icon (shown in Add/Remove Programs) -->
    <Icon Id="AppIcon" SourceFile="..\RetroJukebox\Resources\RetroJukebox.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />

    <!-- Add/Remove Programs metadata -->
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/yourusername/RetroJukebox" />
    <Property Id="ARPHELPLINK"     Value="https://github.com/yourusername/RetroJukebox" />

    <!-- Default install directory: C:\Program Files\RetroJukebox -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="RetroJukebox" />
    </StandardDirectory>

    <!-- Desktop shortcut folder -->
    <StandardDirectory Id="DesktopFolder" />

    <!-- Start Menu folder -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuFolder" Name="RetroJukebox" />
    </StandardDirectory>

    <!-- ── Main application files ────────────────────────────────────────── -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">

      <!-- Main executable -->
      <Component Id="MainExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890">
        <File Id="RetroJukebox.exe"
              Source="$(var.PublishDir)RetroJukebox.exe"
              KeyPath="yes">
          <!-- Desktop shortcut -->
          <Shortcut Id="DesktopShortcut"
                    Directory="DesktopFolder"
                    Name="RetroJukebox"
                    Description="RetroJukebox Music Player"
                    Icon="AppIcon"
                    WorkingDirectory="INSTALLFOLDER"
                    Advertise="no" />
          <!-- Start Menu shortcut -->
          <Shortcut Id="StartMenuShortcut"
                    Directory="StartMenuFolder"
                    Name="RetroJukebox"
                    Description="RetroJukebox Music Player"
                    Icon="AppIcon"
                    WorkingDirectory="INSTALLFOLDER"
                    Advertise="no" />
        </File>
      </Component>

      <!-- All other files from the publish output (DLLs, runtimes, etc.) -->
      <Files Source="$(var.PublishDir)*"
             Exclude="$(var.PublishDir)RetroJukebox.exe" />

    </ComponentGroup>

    <!-- Uninstaller shortcut in Start Menu -->
    <Component Id="UninstallShortcut" Directory="StartMenuFolder"
               Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901">
      <Shortcut Id="UninstallShortcut"
                Name="Uninstall RetroJukebox"
                Description="Remove RetroJukebox from this computer"
                Target="[SystemFolder]msiexec.exe"
                Arguments="/x [ProductCode]" />
      <RemoveFolder Id="CleanStartMenu" Directory="StartMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\RetroJukebox"
                     Name="StartMenuShortcut"
                     Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- Register supported audio file associations (optional — opens files with RetroJukebox) -->
    <Component Id="FileAssociations" Directory="INSTALLFOLDER"
               Guid="C3D4E5F6-A7B8-9012-CDEF-123456789012">
      <RegistryValue Root="HKCR" Key="RetroJukebox.AudioFile"
                     Name="(default)" Value="Audio File" Type="string" KeyPath="yes" />
      <RegistryValue Root="HKCR" Key="RetroJukebox.AudioFile\DefaultIcon"
                     Name="(default)" Value="[INSTALLFOLDER]RetroJukebox.exe,0" Type="string" />
      <RegistryValue Root="HKCR" Key="RetroJukebox.AudioFile\shell\open\command"
                     Name="(default)" Value='"[INSTALLFOLDER]RetroJukebox.exe" "%1"' Type="string" />
    </Component>

    <!-- Feature: main application (required) -->
    <Feature Id="MainFeature" Title="RetroJukebox" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="UninstallShortcut" />
      <ComponentRef Id="FileAssociations" />
    </Feature>

  </Package>
</Wix>
