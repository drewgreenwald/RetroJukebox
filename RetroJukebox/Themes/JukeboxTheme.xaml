<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Color Palette (MusicMatch-inspired dark) ─────────────────────── -->
    <Color x:Key="BgDeepColor">#0D0E12</Color>
    <Color x:Key="BgPanelColor">#13151C</Color>
    <Color x:Key="BgSurfaceColor">#1A1D26</Color>
    <Color x:Key="BgCardColor">#21253A</Color>
    <Color x:Key="BgHoverColor">#2A2E40</Color>
    <Color x:Key="BgSelectedColor">#1E3A5F</Color>

    <Color x:Key="AccentOrangeColor">#FF6A00</Color>
    <Color x:Key="AccentOrangeLightColor">#FF9340</Color>
    <Color x:Key="AccentBlueColor">#3A9BDC</Color>
    <Color x:Key="AccentGreenColor">#4CAF50</Color>

    <Color x:Key="TextPrimaryColor">#E8EAF0</Color>
    <Color x:Key="TextSecondaryColor">#8A90A8</Color>
    <Color x:Key="TextMutedColor">#4A5068</Color>
    <Color x:Key="TextAccentColor">#FF6A00</Color>

    <Color x:Key="BorderColor">#2A2E40</Color>
    <Color x:Key="SeparatorColor">#1E2130</Color>

    <!-- ── Brushes ───────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BgDeepBrush"      Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgPanelBrush"     Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush"   Color="{StaticResource BgSurfaceColor}"/>
    <SolidColorBrush x:Key="BgCardBrush"      Color="{StaticResource BgCardColor}"/>
    <SolidColorBrush x:Key="BgHoverBrush"     Color="{StaticResource BgHoverColor}"/>
    <SolidColorBrush x:Key="BgSelectedBrush"  Color="{StaticResource BgSelectedColor}"/>

    <SolidColorBrush x:Key="AccentOrangeBrush"      Color="{StaticResource AccentOrangeColor}"/>
    <SolidColorBrush x:Key="AccentOrangeLightBrush" Color="{StaticResource AccentOrangeLightColor}"/>
    <SolidColorBrush x:Key="AccentBlueBrush"        Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush"        Color="{StaticResource AccentGreenColor}"/>

    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextAccentBrush"    Color="{StaticResource TextAccentColor}"/>

    <SolidColorBrush x:Key="BorderBrush"    Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}"/>

    <!-- Orange gradient for header/toolbar -->
    <LinearGradientBrush x:Key="ToolbarGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#1A1D26" Offset="0"/>
        <GradientStop Color="#231A10" Offset="0.6"/>
        <GradientStop Color="#2E1A08" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NowPlayingGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E2030" Offset="0"/>
        <GradientStop Color="#13151C" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentButtonGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FF7E20" Offset="0"/>
        <GradientStop Color="#D45000" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SeekBarGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF6A00" Offset="0"/>
        <GradientStop Color="#FF9340" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Typography ─────────────────────────────────────────────────────── -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Consolas</FontFamily>

</ResourceDictionary>
