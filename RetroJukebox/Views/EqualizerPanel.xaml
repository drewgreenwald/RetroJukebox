<UserControl x:Class="RetroJukebox.Views.EqualizerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:RetroJukebox.ViewModels">

    <Border Background="#0D0E12" CornerRadius="6"
            BorderBrush="#2A2E40" BorderThickness="1"
            Padding="10,8">
        <StackPanel>

            <!-- ── Header row ──────────────────────────────────────────── -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Grid.Column="0" Text="EQUALIZER"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="#4A5068"
                           VerticalAlignment="Center" Margin="0,0,10,0"/>

                <!-- Enable toggle -->
                <ToggleButton Grid.Column="1"
                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                              Style="{StaticResource ToggleBtn}"
                              FontSize="10" Padding="8,3"
                              VerticalAlignment="Center">
                    <ToggleButton.Content>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="OFF"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                            <Setter Property="Text" Value="ON"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </ToggleButton.Content>
                </ToggleButton>

                <!-- Preset picker -->
                <ComboBox Grid.Column="3" Width="120" Margin="8,0,0,0"
                          FontSize="11"
                          ItemsSource="{Binding PresetNames}"
                          SelectedItem="{Binding SelectedPreset, Mode=OneWay}"
                          SelectionChanged="Preset_SelectionChanged"/>

                <!-- Reset button -->
                <Button Grid.Column="4" Content="Reset"
                        Style="{StaticResource DarkButton}"
                        FontSize="10" Padding="8,3" Margin="4,0,0,0"
                        Command="{Binding ResetCommand}"/>
            </Grid>

            <!-- ── Band sliders ─────────────────────────────────────────── -->
            <ItemsControl ItemsSource="{Binding Bands}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Center" Margin="2,0">

                            <!-- dB value -->
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="9" FontFamily="Consolas"
                                       Foreground="#8A90A8" Margin="0,0,0,3">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0:+0.0;-0.0;0}">
                                        <Binding Path="GainDb"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- Vertical slider: +12 top, -12 bottom -->
                            <Slider Orientation="Vertical"
                                    Height="100"
                                    Minimum="-12" Maximum="12"
                                    TickFrequency="3"
                                    IsSnapToTickEnabled="False"
                                    Value="{Binding GainDb, Mode=TwoWay}"
                                    HorizontalAlignment="Center"
                                    Foreground="#FF6A00"/>

                            <!-- Frequency label -->
                            <TextBlock Text="{Binding Label}"
                                       HorizontalAlignment="Center"
                                       FontSize="9" Foreground="#8A90A8"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>
