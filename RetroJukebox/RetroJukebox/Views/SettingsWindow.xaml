<Window x:Class="RetroJukebox.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="520" Width="460"
        WindowStartupLocation="CenterOwner"
        Background="#13151C" Foreground="#E8EAF0"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="SETTINGS" FontSize="11" FontWeight="SemiBold"
                   Foreground="#8A90A8" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Audio Device -->
                <TextBlock Text="AUDIO OUTPUT" FontSize="10" Foreground="#FF6A00"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,16">
                    <TextBlock Text="Output Device" Foreground="#8A90A8" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="DeviceCombo" Background="#21253A" Foreground="#E8EAF0"
                              BorderBrush="#2A2E40" Margin="0,0,0,8"/>

                    <TextBlock Text="ASIO Device (Focusrite etc.)" Foreground="#8A90A8" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="AsioCombo" Background="#21253A" Foreground="#E8EAF0"
                              BorderBrush="#2A2E40" Margin="0,0,0,8"/>

                    <TextBlock Text="Output Mode" Foreground="#8A90A8" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="OutputModeCombo" Background="#21253A" Foreground="#E8EAF0"
                              BorderBrush="#2A2E40">
                        <ComboBoxItem Content="WASAPI Shared (default)" Tag="0"/>
                        <ComboBoxItem Content="WASAPI Exclusive (lower latency)" Tag="1"/>
                        <ComboBoxItem Content="ASIO (Focusrite / pro audio)" Tag="3"/>
                        <ComboBoxItem Content="DirectSound (compatibility)" Tag="2"/>
                    </ComboBox>
                </StackPanel>

                <!-- Playback -->
                <TextBlock Text="PLAYBACK" FontSize="10" Foreground="#FF6A00"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,16">
                    <CheckBox x:Name="CrossfadeCheck" Content="Enable Crossfade"
                              Foreground="#E8EAF0" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Crossfade Duration (seconds)" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center"/>
                        <TextBox x:Name="CrossfadeBox" Grid.Column="1" Background="#21253A"
                                 Foreground="#E8EAF0" BorderBrush="#2A2E40" Padding="4,3"/>
                    </Grid>
                    <CheckBox x:Name="GaplessCheck" Content="Enable Gapless Playback"
                              Foreground="#E8EAF0" Margin="0,0,0,8"/>
                </StackPanel>

                <!-- EQ Presets -->
                <TextBlock Text="EQUALIZER" FontSize="10" Foreground="#FF6A00"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>
                <StackPanel Margin="0,0,0,16">
                    <CheckBox x:Name="EqCheck" Content="Enable EQ"
                              Foreground="#E8EAF0" Margin="0,0,0,8"/>
                    <TextBlock Text="Preset" Foreground="#8A90A8" FontSize="11" Margin="0,0,0,4"/>
                    <ComboBox x:Name="EqPresetCombo" Background="#21253A" Foreground="#E8EAF0"
                              BorderBrush="#2A2E40" SelectionChanged="EqPresetChanged">
                        <ComboBoxItem Content="Flat" Tag="0"/>
                        <ComboBoxItem Content="Rock" Tag="1"/>
                        <ComboBoxItem Content="Jazz" Tag="2"/>
                        <ComboBoxItem Content="Classical" Tag="3"/>
                        <ComboBoxItem Content="Folk" Tag="4"/>
                        <ComboBoxItem Content="Pop" Tag="5"/>
                        <ComboBoxItem Content="Electronic" Tag="6"/>
                    </ComboBox>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Apply" Click="Apply"
                    Background="#D45000" Foreground="White"
                    BorderThickness="0" Padding="16,6" Margin="0,0,8,0" Cursor="Hand"/>
            <Button Content="Close" Click="CloseBtn"
                    Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40"
                    BorderThickness="1" Padding="12,6" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
