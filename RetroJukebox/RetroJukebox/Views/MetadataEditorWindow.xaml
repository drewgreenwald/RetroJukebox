<Window x:Class="RetroJukebox.Views.MetadataEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:RetroJukebox.Converters"
        Title="Edit Track Metadata" Height="620" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="#13151C" Foreground="#E8EAF0"
        ResizeMode="CanResize" MinHeight="500" MinWidth="480">

    <Window.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Fields + art -->
            <RowDefinition Height="Auto"/>  <!-- Online search bar -->
            <RowDefinition Height="*"/>     <!-- Results list -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="TRACK METADATA" FontSize="10" FontWeight="SemiBold"
                   Foreground="#FF6A00" Margin="0,0,0,14"/>

        <!-- Fields + Album Art side by side -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
            </Grid.ColumnDefinitions>

            <!-- Fields -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Title" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,7"/>
                <TextBox x:Name="TitleBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,7"
                         Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40" BorderThickness="1" Padding="6,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Artist" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,7"/>
                <TextBox x:Name="ArtistBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,7"
                         Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40" BorderThickness="1" Padding="6,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Album" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,7"/>
                <TextBox x:Name="AlbumBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,7"
                         Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40" BorderThickness="1" Padding="6,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Genre" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,7"/>
                <TextBox x:Name="GenreBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,7"
                         Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40" BorderThickness="1" Padding="6,4"/>

                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Year" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center"/>
                    <TextBox x:Name="YearBox" Grid.Column="1"
                             Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40" BorderThickness="1" Padding="6,4"/>
                    <TextBlock Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="Track #" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center"/>
                    <TextBox x:Name="TrackNumBox" Grid.Column="4"
                             Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40" BorderThickness="1" Padding="6,4"/>
                </Grid>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="File" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,0"/>
                <TextBox x:Name="FilePathBox" Grid.Row="5" Grid.Column="1"
                         Background="#1A1D26" Foreground="#4A5068" BorderBrush="#2A2E40"
                         BorderThickness="1" Padding="6,4" IsReadOnly="True" FontSize="10"/>
            </Grid>

            <!-- Album art -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top">
                <Border Width="100" Height="100" Background="#21253A" BorderBrush="#2A2E40"
                        BorderThickness="1" CornerRadius="4" Margin="0,0,0,6">
                    <Grid>
                        <TextBlock Text="♫" FontSize="28" Foreground="#4A5068"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image x:Name="ArtImage" Stretch="UniformToFill" ClipToBounds="True"/>
                    </Grid>
                </Border>
                <Button Content="Load Image" Click="LoadLocalArt"
                        Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40"
                        BorderThickness="1" Padding="4,4" FontSize="10" Cursor="Hand" Width="100"/>
                <Button Content="Clear Art" Click="ClearArt" Margin="0,4,0,0"
                        Background="#21253A" Foreground="#8A90A8" BorderBrush="#2A2E40"
                        BorderThickness="1" Padding="4,4" FontSize="10" Cursor="Hand" Width="100"/>
            </StackPanel>
        </Grid>

        <!-- Online fetch bar -->
        <Border Grid.Row="2" Background="#1A1D26" BorderBrush="#2A2E40" BorderThickness="1"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="FETCH FROM MUSICBRAINZ"
                           FontSize="9" FontWeight="SemiBold" Foreground="#FF6A00" Margin="0,0,0,8"/>

                <TextBox x:Name="SearchTitleBox" Grid.Row="1" Grid.Column="0"
                         Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40"
                         BorderThickness="1" Padding="6,4" Margin="0,0,6,0"
                         FontSize="11"/>
                <TextBox x:Name="SearchArtistBox" Grid.Row="1" Grid.Column="1"
                         Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40"
                         BorderThickness="1" Padding="6,4" Margin="0,0,6,0"
                         FontSize="11"/>
                <Button Grid.Row="1" Grid.Column="2" Content="Search"
                        Click="FetchOnline" Cursor="Hand"
                        Background="#D45000" Foreground="White"
                        BorderThickness="0" Padding="14,5" FontSize="11"/>
            </Grid>
        </Border>

        <!-- Search hint labels -->
        <Grid Grid.Row="2" Margin="10,8,0,0" IsHitTestVisible="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Title to search…" Foreground="#4A5068"
                       FontSize="11" Margin="2,0,0,0" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchTitleBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBlock Grid.Column="1" Text="Artist to search…" Foreground="#4A5068"
                       FontSize="11" Margin="2,0,0,0" VerticalAlignment="Center">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=SearchArtistBox}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Grid>

        <!-- Results list -->
        <Border Grid.Row="3" Background="#1A1D26" BorderBrush="#2A2E40"
                BorderThickness="1" CornerRadius="4" Margin="0,0,0,8">
            <Grid>
                <TextBlock x:Name="ResultsPlaceholder" Text="Search results will appear here"
                           Foreground="#4A5068" FontSize="11" HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                <ListBox x:Name="ResultsList"
                         Background="Transparent" BorderThickness="0"
                         Foreground="#E8EAF0" FontSize="11"
                         ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                         SelectionChanged="ResultsList_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#2A2E40"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#1E3A5F"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"
                                               Foreground="#E8EAF0" TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Artist}" Foreground="#FF6A00" FontSize="10"/>
                                        <TextBlock Text=" — " Foreground="#4A5068" FontSize="10"/>
                                        <TextBlock Text="{Binding Album}" Foreground="#8A90A8" FontSize="10"/>
                                        <TextBlock Text=" (" Foreground="#4A5068" FontSize="10"
                                                   Visibility="{Binding Year, Converter={StaticResource BoolVis}}"/>
                                        <TextBlock Text="{Binding Year}" Foreground="#4A5068" FontSize="10"
                                                   Visibility="{Binding Year, Converter={StaticResource BoolVis}}"/>
                                        <TextBlock Text=")" Foreground="#4A5068" FontSize="10"
                                                   Visibility="{Binding Year, Converter={StaticResource BoolVis}}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#FF6A00" CornerRadius="3"
                                        Padding="5,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Score, StringFormat='{}{0}%'}"
                                               Foreground="White" FontSize="10" FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Status / progress -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock x:Name="StatusText" Text="" Foreground="#8A90A8" FontSize="11" VerticalAlignment="Center"/>
            <ProgressBar x:Name="FetchProgress" IsIndeterminate="True" Width="120" Height="4"
                         Margin="10,0,0,0" VerticalAlignment="Center"
                         Foreground="#FF6A00" Background="#21253A" BorderThickness="0"
                         Visibility="Collapsed"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="ApplyResultBtn" Content="Apply Selected" Click="ApplyResult"
                    Background="#D45000" Foreground="White" BorderThickness="0"
                    Padding="14,6" Margin="0,0,8,0" Cursor="Hand" IsEnabled="False"/>
            <Button Content="Save to File" Click="Save"
                    Background="#1E3A5F" Foreground="White" BorderBrush="#3A9BDC"
                    BorderThickness="1" Padding="14,6" Margin="0,0,8,0" Cursor="Hand"/>
            <Button Content="Cancel" Click="Cancel"
                    Background="#21253A" Foreground="#E8EAF0" BorderBrush="#2A2E40"
                    BorderThickness="1" Padding="12,6" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
